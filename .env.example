# --- Database ---
HYDRA_DB_HOST=localhost
HYDRA_DB_PORT=5432
HYDRA_DB_NAME=hydra
HYDRA_DB_USER=hydra
HYDRA_DB_PASSWORD=changeme_hydra_db

# --- Redis ---
HYDRA_REDIS_URL=redis://localhost:6379/0

# --- Exchange API Keys ---
# Binance
BINANCE_API_KEY=changeme_binance_api_key
BINANCE_API_SECRET=changeme_binance_api_secret

# Bybit
BYBIT_API_KEY=changeme_bybit_api_key
BYBIT_API_SECRET=changeme_bybit_api_secret

# Kraken
KRAKEN_API_KEY=changeme_kraken_api_key
KRAKEN_API_SECRET=changeme_kraken_api_secret

# OKX
OKX_API_KEY=changeme_okx_api_key
OKX_API_SECRET=changeme_okx_api_secret
OKX_PASSPHRASE=changeme_okx_passphrase

# --- Trading Mode ---
HYDRA_TESTNET=true
HYDRA_PAPER_TRADING=true

# --- Telegram ---
HYDRA_TELEGRAM_BOT_TOKEN=changeme_telegram_bot_token
HYDRA_TELEGRAM_CHAT_ID=changeme_telegram_chat_id

# --- Logging ---
HYDRA_LOG_LEVEL=INFO
HYDRA_LOG_FORMAT=json

# --- Dashboard ---
HYDRA_API_HOST=0.0.0.0
HYDRA_API_PORT=8000
HYDRA_CORS_ORIGINS=http://localhost:3000

# --- ML ---
HYDRA_MODELS_DIR=/app/models
MLFLOW_TRACKING_URI=http://localhost:5000
